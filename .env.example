# PostgreSQL credentials — used by both the postgres service and the api service
POSTGRES_USER=golf
POSTGRES_PASSWORD=golf
POSTGRES_DB=golfleague

# ASP.NET Core — EF Core connection string (double-underscore = nested config key)
ConnectionStrings__Default=Host=postgres;Port=5432;Database=golfleague;Username=golf;Password=golf

# ASP.NET Core — comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Next.js — base URL of the API (must be NEXT_PUBLIC_ to be available in browser)
# Note: port 5000 is reserved by macOS AirPlay on newer Macs; 5001 is used instead
NEXT_PUBLIC_API_URL=http://localhost:5001

# Auth provider — valid values: mock, auth0
# mock: JWT-based dev auth; use /dev/login to select a golfer and receive a signed token
# auth0: validates JWTs against Auth0 JWKS; requires Auth0 tenant setup (see docs/auth0-setup.md)
Auth__Provider=mock

# Auth0 settings — required when Auth__Provider=auth0
Auth__Auth0__Domain=
Auth__Auth0__Audience=

# Mock auth settings — required when Auth__Provider=mock
# Must be > 256 bits (> 32 bytes). Use: openssl rand -base64 33
Auth__Mock__SigningKey=

# Application settings
# The GUID of the default course for this deployment (run: SELECT id FROM courses LIMIT 1)
App__DefaultCourseId=

# Next.js auth provider — controls login page and session handling
# Must match Auth__Provider above
NEXT_PUBLIC_AUTH_PROVIDER=mock
AUTH_PROVIDER=mock

# Auth0 Next.js SDK settings — required when NEXT_PUBLIC_AUTH_PROVIDER=auth0
AUTH0_DOMAIN=
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
